# 1. Obtenha sua chave de API gratuita do Google Gemini em:
# https://aistudio.google.com/app/apikey
# Insira a chave abaixo (substitua SUA_CHAVE_AQUI):
GEMINI_API_KEY=AIzaSyCofHoeKdTVHP2SyymnZD9SbPinMVJrlTk

# 2. O ID do grupo do WhatsApp onde as mensagens serão enviadas.
# Deixe em branco inicialmente. O bot irá imprimir os seus grupos no terminal 
# para você descobrir o ID correto.
WHATSAPP_GROUP_ID=120363407748633135@g.us

# 3. Horário do agendamento (Padrão 08:00 AM) - Expressão CRON
CRON_SCHEDULE="0 8 * * *"
